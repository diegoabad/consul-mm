NODE_ENV=development
PORT=5000

# Zona horaria del servidor (agenda, fechaLocalKey en validación de turnos, etc.). Default también en server.js si no se define.
TZ=America/Argentina/Buenos_Aires

# Database PostgreSQL
# Si DATABASE_URL está definida, se usa (ej. Render). Si no, se usan DB_HOST, etc. (local).
# DATABASE_URL=postgresql://user:password@host:5432/database_name
DB_HOST=localhost
DB_PORT=5432
DB_NAME=consultorio
DB_USER=postgres
DB_PASSWORD=your_password

# Administrador inicial (se crea al arrancar si la DB está vacía y no existe ese email)
ADMIN_EMAIL=admin@consultorio.com
ADMIN_PASSWORD=Admin123!

# JWT
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM="Consultorio <your_email@gmail.com>"
# Aceptar certificado self-signed (proxy/antivirus). En producción podés poner true para verificación estricta.
EMAIL_TLS_REJECT_UNAUTHORIZED=false
# URL del frontend (usado en el email "Usuario creado" para el link de acceso)
LOGIN_URL=https://tu-app.netlify.app

# Resend (opcional). Si definís RESEND_API_KEY, se usa Resend en lugar de SMTP.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM="Consultorio <onboarding@resend.dev>"

# Cifrado de datos sensibles (pacientes, notas, evoluciones, turnos, archivos adjuntos). Mínimo 16 caracteres.
# Sin esta variable los datos se guardan en claro. No cambiar la clave si ya hay datos cifrados.
DATA_ENCRYPTION_KEY=una_frase_larga_y_secreta_de_al_menos_16_caracteres

# Dirección y contacto para el mail de turnos (calle, número, localidad | WhatsApp | Teléfono)
EMAIL_DIRECCION=Calle y número, Localidad
EMAIL_WHATSAPP=11 1234-5678
EMAIL_TELEFONO=11 1234-5678

# Storage LOCAL
UPLOAD_DIR=./uploads
UPLOAD_MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Storage en Azure (opcional). Si las definís, los archivos van a Blob Storage en lugar del disco.
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER_NAME=uploads
# En cloud sin Azure Storage (disco efímero): no borrar registros huérfanos, solo excluirlos de la lista.
# SKIP_ORPHAN_DELETE=1
# Cron diario para subir a Storage lo que esté solo en disco (por defecto 3:00). Formato: "minuto hora * * *"
# CRON_SYNC_STORAGE=0 3 * * *

# Logs
LOG_LEVEL=info
# true = una línea por petición: método, URL y (si hay proxy) x-forwarded-*, origin. Útil en Render para ver qué URL llega.
# LOG_REQUEST_URLS=false

# Rate Limiting (la agenda hace polling; si ves 429 en Render, subí RATE_LIMIT_MAX_REQUESTS o el intervalo VITE_AGENDA_REFETCH_MS en Netlify)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=2000

# CORS (Netlify → API en Render): el Origin del navegador debe estar permitido.
# CORS_ORIGIN o ALLOWED_ORIGINS: coma, sin barra final (se normaliza).
# Con CORS_ORIGIN definido, por defecto también se permiten https://*.netlify.app (previews incluidos).
# Si querés solo los orígenes listados y ningún *.netlify.app: CORS_NETLIFY_PREVIEWS=false
# Front local contra API en Render: CORS_ALLOW_LOCALHOST=true o http://localhost:5173 en CORS_ORIGIN
# Sin CORS_ORIGIN: se permite cualquier origen (solo recomendable en dev).
# CORS_TEST_MODE=true → cualquier Origin (solo pruebas)
# CORS_TEST_MODE=false

# WhatsApp / Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886
# URL pública de la API (para los links de confirmar/cancelar en el mensaje)
# API_PUBLIC_URL=https://tu-dominio.com
# SID de la plantilla con botones CTA (Confirmar / Cancelar con URL + turno_id)
# TWILIO_CONTENT_SID_RECORDATORIO=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Frecuencia del cron de recordatorios (por defecto cada 15 minutos)
CRON_RECORDATORIOS=*/15 * * * *
# Solo para pruebas: enviar recordatorio inmediatamente al crear un turno
WHATSAPP_RECORDATORIO_AL_CREAR=false
